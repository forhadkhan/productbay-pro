{
	"name": "productbay-pro",
	"version": "1.0.0",
	"private": true,
	"description": "Premium add-on for ProductBay — unlock advanced features for your WooCommerce product tables.",
	"author": "WPAnchorBay <support@wpanchorbay.com> (https://wpanchorbay.com/)",
	"contributors": [
		{
			"name": "Forhad Khan",
			"email": "dev@forhadkhan.com",
			"url": "https://forhadkhan.com/"
		}
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/forhadkhan/productbay-pro.git"
	},
	"license": "GPL-2.0-or-later",
	"scripts": {
		"wpbuild": "wp-scripts build",
		"build": "npm-run-all --parallel wpbuild",
		"wpstart": "wp-scripts start",
		"start": "npm-run-all --parallel wpstart",
		"release": "bun scripts/package-plugin.js",
		"release:versioned": "bun scripts/package-plugin.js --versioned",
		"dev:win": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1",
		"dev:win:debug": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1 -Visible",
		"stop:win": "powershell -ExecutionPolicy Bypass -File scripts/stop.ps1",
		"dev:unix": "bash scripts/dev.sh",
		"stop:unix": "bash scripts/stop.sh",
		"dev": "bun run dev:unix",
		"stop": "bun run stop:unix"
	},
	"devDependencies": {
		"@wordpress/dom-ready": "^4.37.0",
		"@wordpress/element": "^6.37.0",
		"@wordpress/i18n": "^6.10.0",
		"@wordpress/scripts": "^31.2.0",
		"archiver": "^7.0.1",
		"fs-extra": "^11.3.3",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@wordpress/components": "^32.3.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.7.0",
		"tailwind-merge": "^3.4.0"
	}
}